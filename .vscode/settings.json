{
  "chat.tools.terminal.autoApprove": {
    "npm run test": true,
    "git stash": true,
    "git apply": true,
    "patch": true,
    "npm test": true,
    "mise": true,
    "make": true,
    "/^bash -n booster/integrate_booster\\.sh$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^bash -n booster/src/main\\.sh$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^bash booster/build\\.sh$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
